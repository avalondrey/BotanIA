# ═══ BotanIA — Environment Variables ═══
# Copy this file to .env.local and fill in your values.
# Variables with defaults work without configuration for local development.

# ─── AI / LLM ───

# Ollama (local LLM server — https://ollama.ai)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_IMAGE_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=bakllava
OLLAMA_HOST=http://localhost:11434
OLLAMA_SYSTEM_PROMPT=Tu es BotanIA, expert jardinage bio.
ENABLE_OLLAMA=true

# Groq Cloud (https://console.groq.com)
NEXT_PUBLIC_GROQ_API_KEY=
GROQ_API_KEY=

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Google Gemini
NEXT_PUBLIC_GEMINI_API_KEY=

# Plant.id (plant identification API — https://plant.id)
PLANTID_API_KEY=DEMO
PLANT_ID_KEY=

# Builder.io (visual CMS)
NEXT_PUBLIC_BUILDER_API_KEY=

# ─── Vector Database ───

# Qdrant (local vector DB — https://qdrant.tech)
NEXT_PUBLIC_QDRANT_URL=http://localhost:6333

# ─── AI Microservice ───

# URL du microservice AI (ex: https://pc-avalondrey.tail56d862.ts.net/)
NEXT_PUBLIC_AI_MICROSERVICE_URL=

# Secret HMAC partagé avec le microservice (doit correspondre à AI_MICROSERVICE_SECRET côté microservice)
NEXT_PUBLIC_AI_MICROSERVICE_SECRET=

# ─── Security ───

# Secret token for PlantCard validation endpoint
VALIDATE_PLANT_SECRET=

# ─── Weather ───
# Open-Meteo is used by default (no key required)

# ─── Next.js ───
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434